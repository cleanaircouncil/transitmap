---
import Nav from "./nav.astro";
import Header from "./header.astro";

import Map from "./map.astro";
import ResponsiveSheet from "./responsive-sheet.astro";

const { venue } = Astro.props

---

<main id="app" class="app layout-app" data-app>
  <section class="in-header">
    <Header>
      <slot name="header"/>
    </Header>

  </section>

  <ResponsiveSheet class="in-list">
    <div class="scroller">
      <slot/>
    </div>
  </ResponsiveSheet>

  
  <section class="in-main">
    <Map venue={ venue }/>
  </section>
<!-- 
  <section class="in-nav">
    <Nav/>
  </section> -->
</main>

<style>
  .app {
    position: absolute;
    inset: 0px;
    padding: 0px;

    font-family: var(--font-default);
    background: var(--color-white);
    color: var(--color-black);
    overflow: hidden;
  }

  .layout-app {
    display: grid;
  }

  .in-list {
    position: relative;
   
  }

  .scroller {
    overflow: auto;
    padding-bottom: 10vh;
    height: 100%;
  }

  .in-main {
    grid-area: main;
    position: relative;
  }

  .in-header {
    grid-area: header;
  }

  @media screen and (max-width: 600px) {
    .layout-app {
      grid-template-rows: min-content 1fr min-content;
      grid-template-areas:
        "header"
        "main"
        "nav";
    }

    .in-list {
      pointer-events: none;
      grid-area: main;
      z-index: 20;
    }

    .in-nav {
      grid-area: unset;
    }
  }

  @media screen and (min-width: 600px) {
    .layout-app {
      grid-template-columns: min(45vw, 450px) 1fr;
      grid-template-rows: min-content 1fr;
      grid-template-areas:
        "header main"
        "list main"
        "nav main";
    }

    .in-list {
      grid-area: list;
    }

    .in-nav {
      grid-area: nav;
    }
  }


</style>

<style is:global>
  .header-nav {
    position: absolute;
    z-index: 20;
    display: flex;
    left: 1rem;
    right: 1rem;
    justify-content: space-between;
  }
</style>



<script>
  const stickyEls = document.querySelectorAll("[data-sticky]");

  const stickyObserver = new IntersectionObserver(
    ([e]) => {
      const value = !e.isIntersecting ? "stuck" : ""
      e.target.dataset.sticky = value;
    },{
      rootMargin: "-1px 0px 0px 0px",
      threshold: [1],
    }
  )

  stickyEls.forEach(stickyEl => {
    stickyObserver.observe(stickyEl);
  })


  
  document.addEventListener('astro:page-load', () => {
    const stickyEls = document.querySelectorAll("[data-sticky]");
      stickyEls.forEach(stickyEl => {
      stickyObserver.observe(stickyEl);
    })
  });


  document.addEventListener("click", (e) => {
    console.log("Fwef");
    const openChipEl = e.target.closest("[data-open-chip]");
    const closeChipEl = e.target.closest("[data-close-chip]");
    const stopChipEl = e.target.closest("[data-stop-chip]")

    if( !openChipEl && !closeChipEl )
      return;

    if( openChipEl ) {
      document.querySelectorAll("[data-stop-chip='open']").forEach( stopChipEl => stopChipEl.setAttribute("data-stop-chip", "") );
      stopChipEl.setAttribute("data-stop-chip", "open");
    }

    if( closeChipEl ) {
      stopChipEl.setAttribute("data-stop-chip", "");
    }


  })

</script>