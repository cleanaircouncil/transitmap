      line-height: 1;
    }
  } */

  .listing-compact__details {
    /* background: var(--color-white); */
    color: var(--color-black);
    text-decoration: none;
  }
  
  .listing-compact__group {
    color: var(--color-red);
    line-height: 1;
    font-weight: 900;
    text-transform: uppercase;
  }

  .listing-compact__meta {
    color: var(--color-gray);
    font-weight: 900;
    text-transform: uppercase;
  }

  .listing-compact__name {
    font-weight: 500;
    font-style: italic;
    font-size: 1.3rem;
    line-height: 1;
