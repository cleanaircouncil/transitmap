---
import ReplaceFlags from "./replace-flags.astro";

const { listing } = Astro.props;

const date = (listing.date !== undefined) ? new Date(listing.date) : new Date();
const time = Intl.DateTimeFormat("en-US", {hour: "numeric"}).format(date);
---

<div class="listing_info stack-tight">
  <div class="listing__group">{ listing.group_name }</div>

  <div class="listing__name">
    <ReplaceFlags title={ listing.name }/>
  </div>

  <div class="listing__meta">
    <span class="listing__time">{ time }</span>
    <span>@</span>
    <a class="listing__venue" href={`/venues/${listing.venue_id}`}>{ listing.venue }</a>
  </div>

</div>


<style>

  .listing__explore {
    text-align: center;
    
    display: block;
    font-size: 1rem;
    font-style: italic;
  }

  .listing__details {
    color: var(--color-black);
    text-decoration: none;
  }
  
  .listing__group {
    color: var(--color-gpg-green-dark);
    line-height: 1;
    font-weight: 900;
    text-transform: uppercase;
  }

  .listing__meta {
    color: var(--color-gray);
    font-weight: 700;
    /* text-transform: uppercase; */
    font-size: 1.1rem;

    a {
      color: var(--color-gray);
      text-decoration: none;
    }
  }

  .listing__name {
    font-weight: 500;
    font-style: italic;
    font-size: 1.3rem;
    line-height: 1;
  }

  .listing__time {
    color: var(--color-black);
  }


  </style>