---
const { route = {} } = Astro.props;

---

<div
  class="transit-chip"
  data-transit-chip
  data-populate="
    route_color: --route-color, 
    route_text_color: --text-color, 
    mode: @data-mode,
    agency: @data-agency,
    key: @data-key
  "
  data-mode={route.mode}
  data-agency={route.agency}
  data-key={route.key}
  style={`
    --route-color: ${route.route_color};
    --text-color: ${route.route_text_color};
  `}
>
  <span class="transit-chip__text" data-populate="route_short_name">{ route.route_short_name }</span>
  <span class="transit-chip__label" data-populate="company_name"></span>
</div>



<style is:global>
 

  .transit-chip {
    min-width: 2rem;
    height: 2rem;
    background: var(--route-color);
    color: var(--text-color);
    font-family: var(--font-default);
    font-weight: 900;
    place-content: center;
    text-align: center;
    background-size: contain;
    cursor: pointer;

    box-shadow: 0px 5px 0px rgba(0,0,0,.10);

    .transit-chip__text {
      display: block;
      width: calc( 100% - 4px );
      height: calc( 100% - 4px );
      font-size: 1em;
      line-height: 1;
      place-content: center;
      margin: 2px;
    }

    &[data-mode="Bike"] {
      border-radius: 12px;
      min-width: unset;
      width: 24px;
      height: 24px;
      background: #3980C4;
      color: var(--color-white);
      place-content: center;

      .transit-chip__text {
        display: none;
      }


      &::after {
        content: '\f206';
        display: block;
        font: var(--fa-font-solid);
        width: 100%;
        height: 100%;
        font-size: 12px;
        line-height: 24px;
      }
    }


    &[data-mode="Bus"] {
      border-radius: 18px;
      background: var(--route-color);
      color: var(--text-color);
      
      /* &[data-agency="SEPTA"] {
        background: var(--color-black);
        color: var(--color-white);
      }

      &[data-agency="NJ Transit"] {
        background: var(--color-white);
        color: var(--color-black);
      } */

      .transit-chip__text {
        border: .1rem solid currentColor;
        border-radius: 16px;
        padding-inline: 10px;
      }
    }

    &[data-mode="Metro"] {
      border-radius: 5px;

      .transit-chip__text {
        /* border: 1px solid white; */
        border-radius: 3px;
      }

    }

    &[data-agency="PATCO"] {
      width: auto;

      .transit-chip__text{
        border: none;
        padding-inline: 5px;
      }
    }

    &[data-agency="Philly Phlash"] {
      width: auto;

      border-radius: 20px;

      .transit-chip__text{
        /* border: none; */
        /* padding-inline: 5px; */
      }
    }

    &[data-mode="Rail"] {
      border-radius: 5px;
      width: 48px;
    }
  }


  .transit-chip:hover {
    z-index: 2;
  }

  .transit-chip.is-dimmed {
    --factor: 0.8; /* Should range only between 0 and 1 */
    filter: invert(calc(var(--factor) / 2)) brightness(calc(1 + var(--factor)));
  }

  .transit-chip:not(.is-dimmed) {
    z-index: 1;
  }

  @media screen and (min-width: 600px) {
    .transit-chip {
      font-size: 20px;
      border: 20px solid red !;
    }
  }


</style>





<script>
  import { updateSearchParam } from "../helpers/location";
  import { currentRoute, toggleRouteDisplay } from "../helpers/store";


  document.addEventListener("click", (e) => {
    const transitChipEl = e.target.closest("[data-transit-chip]");
    if( !transitChipEl )
      return;

    e.preventDefault();
    
    toggleRouteDisplay( transitChipEl.dataset.key );
  })

  currentRoute.subscribe( (key) => {
    updateSearchParam("route", key);
    
    const transitChipEls = document.querySelectorAll(`[data-transit-chip]`)
    transitChipEls.forEach( transitChipEl => {
      transitChipEl.classList.toggle("is-dimmed", Boolean(key) && (transitChipEl.dataset.key != key))
    })
  })

</script> 