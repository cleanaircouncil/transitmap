---
import App from "../components/app.astro";
import Layout from "./layout.astro";

import "../styles/styles.css";


const { title = "Go Philly Go: Car-Free Routes", venue } = Astro.props;
---


<Layout title={ title }>
  <App venue={venue}>
    <slot name="header" slot="header"/>
    <slot/>
  </App>
</Layout>